<!-- Inline mini-timeline rendered as a table column on the Series
     object page's Episodes facet. One bar per episode row (segments
     are per-file).

     The aggregation pattern is required: a property binding to a
     v4 navigation collection fails with
     "Type 'sap.ui.model.odata.type.Raw' does not support formatting".
     The manifest forces $expand=segments at the table binding level
     so the row's segments collection is already cached when this
     template renders. -->
<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:ext="com.nalet.katalog.ext.control">
  <ext:SegmentBar durationMs="{durationMs}"
                  entries="{path: 'segments', length: 500, templateShareable: true}">
    <ext:SegmentRow kind="{kind}" startMs="{startMs}" endMs="{endMs}" source="{source}"/>
  </ext:SegmentBar>
</core:FragmentDefinition>
