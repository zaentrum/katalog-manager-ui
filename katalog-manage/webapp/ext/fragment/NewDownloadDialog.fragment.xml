<!--
  "New download" dialog for the Downloads List Report. Plain sap.m controls
  (no OData binding) — on Queue the controller POSTs to
  /katalog-api/api/downloads, which forwards to the download-gateway. The
  read model (the table) catches up a few seconds later via the Kafka
  projection, so we just toast + close.
-->
<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">
  <Dialog id="newDownloadDialog" title="New download" contentWidth="34rem" draggable="true">
    <content>
      <f:SimpleForm layout="ResponsiveGridLayout" editable="true" labelSpanXL="3" labelSpanL="3" labelSpanM="3">
        <f:content>
          <Label text="Client" required="true" />
          <Select id="ndAdapter" forceSelection="true" width="100%">
            <core:Item key="odownloader" text="oDownloader (JDownloader, via VPN)" />
            <core:Item key="qbittorrent" text="qBittorrent (torrent, via VPN)" />
            <core:Item key="nzbget" text="NZBGet (usenet, direct)" />
          </Select>

          <Label text="Source" required="true" />
          <Input id="ndSource" placeholder="URL, magnet link, or .nzb URL" />

          <Label text="Title" />
          <Input id="ndTitle" placeholder="Optional — shown in the downloads list" />

          <Label text="Katalog item id" />
          <Input id="ndWanted" placeholder="Optional — links this download to a catalog item" />
        </f:content>
      </f:SimpleForm>
    </content>
    <beginButton>
      <Button text="Queue" type="Emphasized" press="onQueueDownload" />
    </beginButton>
    <endButton>
      <Button text="Cancel" press="onCancelDialog" />
    </endButton>
  </Dialog>
</core:FragmentDefinition>
