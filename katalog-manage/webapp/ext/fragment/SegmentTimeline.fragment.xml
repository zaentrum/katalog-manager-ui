<!-- Custom section rendered on the Movies + Episodes object page. Pulls
     the item's segments composition (already exposed in OData via the
     KatalogService.Episodes/Movies → segments association) and renders
     a single proportional bar with hover tooltips, plus a colour
     legend.

     The `entries` aggregation receives one SegmentRow per row of the
     `segments` association — the only way to bind an OData v4
     navigation collection into a custom UI5 control. Plain property
     bindings on collection-typed paths fail with
     "Type 'sap.ui.model.odata.type.Raw' does not support formatting". -->
<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:ext="com.nalet.katalog.ext.control">
  <VBox class="sapUiSmallMargin kg-segment-timeline">
    <ext:SegmentBar durationMs="{durationMs}"
                    entries="{path: 'segments', length: 500, templateShareable: true}">
      <ext:SegmentRow kind="{kind}" startMs="{startMs}" endMs="{endMs}" source="{source}"/>
    </ext:SegmentBar>

    <!-- Legend, TIDB-aligned (intro / recap / credits / preview). The
         neutral content tone is the bar background. File-internal
         chapter markers, when present, are surfaced via the sibling
         ItemChapters entity and rendered on a separate row above. -->
    <HBox class="sapUiTinyMarginTop kg-segment-legend" wrap="Wrap">
      <HBox class="kg-legend-item"><Label class="kg-swatch kg-swatch-intro"   text=""/><Text text="Intro"/></HBox>
      <HBox class="kg-legend-item"><Label class="kg-swatch kg-swatch-recap"   text=""/><Text text="Recap"/></HBox>
      <HBox class="kg-legend-item"><Label class="kg-swatch kg-swatch-credits" text=""/><Text text="Credits"/></HBox>
      <HBox class="kg-legend-item"><Label class="kg-swatch kg-swatch-preview" text=""/><Text text="Preview"/></HBox>
      <HBox class="kg-legend-item"><Label class="kg-swatch kg-swatch-scene"   text=""/><Text text="Content"/></HBox>
    </HBox>
  </VBox>
</core:FragmentDefinition>
